# Configuration de l'environnement pour AutoApply
# Copiez ce fichier en .env et modifiez les valeurs selon votre environnement

# Configuration du serveur
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Configuration de la base de données
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/autoapply"

# Configuration de Notion (optionnel)
NOTION_TOKEN=""
NOTION_DATABASE_ID=""

# Configuration de l'API Perplexity (optionnel)
PERPLEXITY_API_KEY=""

# Configuration des logs
LOG_LEVEL=info
DISABLE_VERBOSE_LOGGING=true

# Configuration HTTPS (pour la production)
SSL_KEY_PATH=""
SSL_CERT_PATH=""

# Configuration Firebase
# Option 1 : fichier JSON (dev) — placer firebase-service-account.json a la racine
FIREBASE_SERVICE_ACCOUNT_PATH="./firebase-service-account.json"
# Option 2 : variables d'environnement (production)
FIREBASE_DATABASE_URL=""
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Anthropic Claude API
ANTHROPIC_API_KEY=""

# Configuration JWT — CHANGEZ CE SECRET en production !
JWT_SECRET="CHANGEZ-MOI-utilisez-une-chaine-aleatoire-de-64-chars"
JWT_EXPIRES_IN="7d"

# Configuration Session — CHANGEZ CE SECRET en production !
SESSION_SECRET="CHANGEZ-MOI-utilisez-une-chaine-aleatoire-de-64-chars"
