{
  "name": "middleware-rh",
  "version": "1.0.0",
  "description": "Middleware pour le projet AutoApply",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run clean && npm run copy-static",
    "clean": "rimraf dist",
    "copy-static": "copyfiles -u 1 public/**/* dist/",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "import-candidatures": "node scripts/importCandidaturesFromJson.js"
  },
  "keywords": [
    "autoapply",
    "middleware",
    "rh",
    "notion"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@prisma/client": "^6.19.2",
    "axios": "^1.8.2",
    "compression": "^1.8.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.18.1",
    "firebase-admin": "^12.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.4",
    "puppeteer": "^24.4.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "prisma": "^6.19.2",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "extensionsToTreatAsEsm": [
      ".js"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
